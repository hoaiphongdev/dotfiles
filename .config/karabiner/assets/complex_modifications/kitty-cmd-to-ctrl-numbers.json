{
    "title": "Kitty: ⌘ + 1..9 → ⌃ + 1..9",
    "rules": [
      {
        "description": "Kitty: Change cmd + number (1-9) to ctrl + number (only in Kitty)",
        "manipulators": [
          {
            "type": "basic",
            "from": {
              "key_code": "1",
              "modifiers": {
                "mandatory": ["left_command", "right_command"],
                "optional": ["any"]
              }
            },
            "to": [
              {
                "key_code": "1",
                "modifiers": ["left_control", "right_control"]
              }
            ],
            "conditions": [
              {
                "type": "frontmost_application_if",
                "bundle_identifiers": ["^com\\.kovidgoyal\\.kitty$"]
              }
            ]
          },
