{
  "title": "Ghostty: ⌘ + 1..9 → ⌃ + 1..9",
  "rules": [
    {
      "description": "Ghostty: Change cmd + number (1-9) to ctrl + number (only in Ghostty)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "1",
            "modifiers": {
              "mandatory": [
                "left_command",
                "right_command"
              ],
              "optional": [
                "caps_lock",
                "option",
                "control"
              ]
            }
          },
          "to": [
            {
              "key_code": "1",
              "modifiers": [
                "left_control",
                "right_control"
              ]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.mitchellh\\.ghostty$"
              ]
            }
          ]
        },
