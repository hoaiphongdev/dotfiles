layout {
  default_tab_template {
    children
    pane size=1 borderless=true {
      plugin location="zellij:compact-bar"
    }
  }

  tab name="[LUMIN] INNOVATE ✨" {
    pane split_direction="vertical" {
      pane name="Git" size="22%" cwd="~/Documents/workspaces/lumin/innovation/ai-power-search"
      pane name="Main command" focus=true size="38%" cwd="~/Documents/workspaces/lumin/innovation/ai-power-search"
      pane split_direction="horizontal" size="40%" {
        pane name="Aux 1" size="25%" cwd="~/Documents/workspaces/lumin/innovation/ai-power-search"
        pane name="Aux 2" size="25%" cwd="~/Documents/workspaces/lumin/innovation/ai-power-search"
        pane name="Aux 3" size="25%" cwd="~/Documents/workspaces/lumin/innovation/ai-power-search"
        pane name="Aux 4" size="25%" cwd="~/Documents/workspaces/lumin/innovation/ai-power-search"
      }
    }
  }
}
